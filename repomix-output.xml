      {/* Discount Rows */}
      <div className="divide-y divide-slate-100">
        {discounts.map((discount, index) => (
          <DiscountRow
            key={discount.id}
            discount={discount}
            index={index}
            onUpdate={onUpdateDiscount}
            onRemove={onRemoveDiscount}
          />
        ))}
      </div>

      {/* Add Discount Button */}
      <div className="p-4 border-t border-slate-200 bg-slate-50/30">
        <Button
          variant="outline"
